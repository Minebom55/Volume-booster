{
  "manifest_version": 2,
  "name": "Volume Booster",
  "version": "1.0.0",
  "description": "Boost webpage audio and video volume beyond 100% using the Web Audio API.",
  "applications": {
    "gecko": {
      "id": "volume-booster@local",
      "strict_min_version": "57.0"
    }
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "browser_action": {
    "default_title": "Volume Booster",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
